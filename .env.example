APP_NAME=KB Copilot API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_copilot

CHUNK_SIZE=700
CHUNK_OVERLAP=120
TOP_K=5

# Tencent Hunyuan embedding uses an OpenAI-compatible /embeddings endpoint.
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
EMBEDDING_API_KEY=your-hunyuan-api-key
EMBEDDING_MODEL=hunyuan-embedding
EMBEDDING_DIMENSION=1024

# DeepSeek uses an OpenAI-compatible /chat/completions endpoint.
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# MinIO object storage for original documents (optional, disabled by default)
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_BUCKET=kb-copilot-documents
MINIO_SECURE=false
